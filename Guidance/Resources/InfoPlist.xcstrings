            "value": "Lokasi Anda digunakan untuk menghitung waktu salat di wilayah Anda."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konumunuz, bölgeniz için namaz vakitlerini hesaplamak amacıyla kullanılır."
          }
        },
        "fa": {
