          }
        }
      }
    },
    "NSAppleEventsUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "توقف هداية تطبيق الموسيقى أو iTunes مؤقتًا قبل تشغيل الأذان."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance pauses Music or iTunes before playing the adhan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance met Music ou iTunes en pause avant de lancer l'adhan."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اذان چلانے سے پہلے Guidance، Music یا iTunes کو موقوف کر دیتا ہے۔"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance menjeda Music atau iTunes sebelum memutar azan."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance, ezanı çalmadan önce Music veya iTunes'u duraklatır."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance پیش از پخش اذان، Music یا iTunes را موقتاً متوقف می‌کند."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আজান বাজানোর আগে Guidance, Music বা iTunes সাময়িকভাবে থামায়।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance menjeda Music atau iTunes sebelum memainkan azan."
          }
        }
      }
    },
    "NSLocationUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم موقعك لحساب أوقات الصلاة في منطقتك."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your location is used to calculate prayer times for your area."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre position est utilisée pour calculer les heures de prière dans votre région."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "آپ کے علاقے کے اوقاتِ نماز کا حساب لگانے کے لیے آپ کا مقام استعمال ہوتا ہے۔"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokasi Anda digunakan untuk menghitung waktu salat di wilayah Anda."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konumunuz, bölgeniz için namaz vakitlerini hesaplamak amacıyla kullanılır."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "از موقعیت مکانی شما برای محاسبه اوقات شرعی منطقه‌تان استفاده می‌شود."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আপনার এলাকার নামাজের সময় গণনা করতে আপনার অবস্থান ব্যবহার করা হয়।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokasi anda digunakan untuk mengira waktu solat bagi kawasan anda."
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يستخدم موقعك لحساب أوقات الصلاة في منطقتك."
          }
        },
