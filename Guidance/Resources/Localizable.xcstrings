    "settings.adj.delayedIsha": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تأخير العشاء في رمضان"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delayed Isha in Ramadan"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Retard de l'Isha en Ramadan"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "رمضان میں عشاء میں تاخیر"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Isya diperlambat saat Ramadan"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ramazan'da Yatsıyı geciktir"
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "تأخیر عشاء در رمضان"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "রমজানে এশা বিলম্বিত"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Lewatkan Isyak pada Ramadan"
          }
        }
      }
    },
    "settings.adj.delayedIsha.footer": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يمدد فترة العشاء إلى 120 دقيقة خلال رمضان للطرق التي تستخدم فاصلا ثابتا."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extends Isha interval to 120 minutes during Ramadan for methods that use a fixed interval."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Étend l'intervalle de l'Isha à 120 minutes pendant le Ramadan pour les méthodes utilisant un intervalle fixe."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ان طریقوں کے لیے جو مقررہ وقفہ استعمال کرتے ہیں، رمضان کے دوران عشاء کا وقفہ 120 منٹ تک بڑھا دیتا ہے۔"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Memperpanjang interval Isya menjadi 120 menit selama Ramadan untuk metode yang menggunakan interval tetap."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sabit aralık kullanan yöntemlerde Ramazan boyunca Yatsı aralığını 120 dakikaya uzatır."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "بازه عشاء را در ماه رمضان برای روش‌هایی که از بازه ثابت استفاده می‌کنند به ۱۲۰ دقیقه افزایش می‌دهد."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "নির্দিষ্ট ব্যবধান ব্যবহারকারী পদ্ধতিগুলোর জন্য রমজানে এশার ব্যবধান 120 মিনিট পর্যন্ত বাড়ায়।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Memanjangkan selang Isyak kepada 120 minit semasa Ramadan bagi kaedah yang menggunakan selang tetap."
          }
        }
      }
    },
    "settings.adj.hijriHeader": {
