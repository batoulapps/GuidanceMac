    "settings.adj.offsetsFooter": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "إزاحة أوقات الصلاة بالدقائق. سالب للتقديم، موجب للتأخير."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shift individual prayer times by minutes. Negative for earlier, positive for later."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Décale les heures de prière en minutes. Négatif pour avancer, positif pour retarder."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "انفرادی اوقاتِ نماز کو منٹوں میں آگے پیچھے کریں۔ منفی پہلے کے لیے، مثبت بعد کے لیے۔"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Geser waktu salat per menit. Negatif untuk lebih awal, positif untuk lebih lambat."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Namaz vakitlerini dakika cinsinden kaydırın. Erkene almak için negatif, geciktirmek için pozitif."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "اوقات هر نماز را برحسب دقیقه جابه‌جا کنید. منفی برای جلوتر، مثبت برای دیرتر."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "প্রতিটি নামাজের সময় মিনিটে সরান। আগে করতে ঋণাত্মক, পরে করতে ধনাত্মক।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anjak waktu solat individu dalam minit. Negatif untuk lebih awal, positif untuk lebih lewat."
          }
        }
      }
    },
    "settings.adj.offsetsHeader": {
