    "settings.notif.permission.denied": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تنبيهات هداية متوقفة في إعدادات النظام. فعّلها من إعدادات النظام."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance notifications are off in System Settings. Enable them in System Settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les notifications de Guidance sont désactivées dans Réglages Système. Activez-les dans Réglages Système."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance کے نوٹیفکیشنز سسٹم کی ترتیبات میں بند ہیں۔ انہیں سسٹم کی ترتیبات میں فعال کریں۔"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Notifikasi Guidance nonaktif di Pengaturan Sistem. Aktifkan di Pengaturan Sistem."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance bildirimleri Sistem Ayarları'nda kapalı. Sistem Ayarları'ndan etkinleştirin."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "اعلان‌های Guidance در تنظیمات سیستم خاموش است. آن‌ها را در تنظیمات سیستم فعال کنید."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সিস্টেম সেটিংসে Guidance-এর বিজ্ঞপ্তি বন্ধ আছে। সিস্টেম সেটিংস থেকে এগুলো সক্রিয় করুন।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pemberitahuan Guidance dimatikan dalam Tetapan Sistem. Aktifkannya dalam Tetapan Sistem."
          }
        }
      }
    },
    "settings.notif.permission.error": {
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر طلب إذن التنبيهات. تحقق من إعدادات النظام."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance could not request notification permission. Check System Settings."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de demander l'autorisation des notifications. Vérifiez Réglages Système."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance نوٹیفکیشن کی اجازت طلب نہیں کر سکا۔ سسٹم کی ترتیبات چیک کریں۔"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance tidak dapat meminta izin notifikasi. Periksa Pengaturan Sistem."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance bildirim izni isteyemedi. Sistem Ayarları'nı kontrol edin."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance نتوانست اجازه اعلان را درخواست کند. تنظیمات سیستم را بررسی کنید."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance বিজ্ঞপ্তির অনুমতি চাইতে পারেনি। সিস্টেম সেটিংস পরীক্ষা করুন।"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Guidance tidak dapat meminta kebenaran pemberitahuan. Semak Tetapan Sistem."
          }
        }
      }
    },
    "settings.notif.permission.unknown": {
      "localizations": {
        "ar": {
